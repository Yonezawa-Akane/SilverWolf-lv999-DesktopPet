{
  "name": "silver-wolf-pet",
  "version": "2.0.0",
  "description": "Silver Wolf Shimeji Desktop Pet",
  "main": "main.js",
  "author": "Fan Project",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . SilverWolfPet --platform=win32 --arch=x64 --out=dist --overwrite --icon=assets/icon.ico --electron-version=28.3.3 --ignore=node_modules --ignore=dist --ignore=^/scripts --ignore=^/docs --ignore=^/build\\.bat$ --ignore=^/\\.claude --ignore=^/assets/launcher_raw\\.png$ --ignore=^/assets/sw_side\\.png$ --ignore=^/assets/sw_sprite\\.png$ --ignore=^/assets/sw_sprite_flip\\.png$"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "@electron/packager": "^18.3.5"
  }
}

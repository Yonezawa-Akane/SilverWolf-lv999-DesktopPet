    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^3.11.174",
    "turndown": "^7.2.4",
    "xlsx": "^0.18.5"
  }

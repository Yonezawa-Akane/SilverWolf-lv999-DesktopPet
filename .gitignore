# ---------- Node / Electron ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Build output ----------
dist/
out/
build/
*.zip
*.exe
*.nupkg
*.AppImage
*.dmg

# ---------- Runtime / user state ----------
# state.json + launcher_pos.json live under %APPDATA%\silver-wolf-pet,
# but ignore any local copies to be safe.
state.json
launcher_pos.json
*.log

# ---------- Secrets ----------
.env
.env.*
*.pem
*.key
secrets/
config.local.*

# ---------- Editor / OS ----------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------- Local Claude / agent metadata ----------
.claude/
.claude-cache/

# ---------- Python (gen_icon.py 等脚本副产物) ----------
__pycache__/
*.pyc
*.pyo
*.egg-info/

# ---------- Misc generated assets ----------
assets/launcher_raw.png

# ---------- Voice input model weights ----------
# Model files are large (~234MB int8 / ~938MB fp32) and re-downloadable from
# https://github.com/k2-fsa/sherpa-onnx/releases (asr-models tag).
# Setup instructions: docs/voice-input-spec.md §8.1
# tokens.txt and LICENSE.txt are kept in git so collaborators can verify
# directory shape and license attribution.
assets/models/sense-voice/*.onnx
assets/models/sense-voice/*.bin
assets/models/silero_vad.onnx

# release-assets: vc_redist.x64.exe 太大，由开发者本地放置
release-assets/vc_redist.x64.exe
release-assets/*.exe

# release: 发布 zip，体积太大不入 git
release/
